            ],
            "parameters": [
                {
                    "extIsId": "594BD2VS",
                    "paramCode": "ASPARAM658",
                    "productId": "DB2B98FC-0593-4676-9965-C91725E21D2E",
                    "amount": 5,
                    "warehouseCode": "1",
                    "extProductCode": "PRPARAM254",
                    "commission": "D254185",
                    "batch": "LOT548721",
                    "batchExt": "LOT_225466",
