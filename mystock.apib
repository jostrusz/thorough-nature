            "specification": "SPEC_01",
            "items": [
                {
                    "itemCode": "VD_POL_001",
                    "extIsId": "2EDC6076",
                    "productId": "B587A515-1BF0-46A9-8166-9319FD962C2D",
                    "name": "Dell G5 15 Gaming (5521) Special Edition",
                    "amount": {
                        "quantity": 5,
                        "measurementUnitCode": "KS"
                    },
                    "locationCode": "ASSEMBLY",
                    "batch": "LOT220217",
                    "batchExt": "LOT_2254",
                    "expirationDate": "2023-09-24",
                    "countryOfOriginId": "CZ",
                    "variant": "RIGHT",
                    "commission": "C208211",
                    "correctedDocumentId": "ADA11CBB-8E63-4C17-AB9A-6B83E54BC56B",
                    "correctedItemId": "23F3A544-A7D3-462B-947D-AF3CCD1BD29B",
                    "note": "Note of the item",
                    "qualityId": "DCE838E1-5A27-48EF-9746-7E1C62791776"
                }
            ]
        }

+ Response 201 (application/json)

        {
          "data": {
            "ids": [
              {
                "id": "3327C671-8AB7-4DF2-8802-1E5683ECFDE5",
                "recordId": "0",
                "sourceId": "D77F6803",
                "type": "issue"
              },
              {
                "id": "5C841FC8-804A-45FA-B4E1-44D67A71BDB6",
                "recordId": "1",
