        {
            "data": null,
            "errors": [
                {
                    "errorText": "The entered value is NULL",
                    "errorType": 1,
                    "internalRecordId": null,
                    "propertyName": "name",
                    "recordId": "1",
                    "recordType": "itemList",
                    "sourceId": "648DC0FF "
                }
            ]
