{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "port": 9000,
      "cwd": "backend"
    },
    {
      "name": "storefront",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 8000,
      "cwd": "storefront"
    },
    {
      "name": "storefront-only",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["next", "dev", "-p", "8000"],
      "port": 8000,
      "cwd": "storefront"
    },
    {
      "name": "email-dev",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["email:dev"],
      "port": 3002,
      "cwd": "backend"
    },
    {
      "name": "dashboard-preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", ".", "-p", "8080", "-c-1"],
      "port": 8080
    },
    {
      "name": "loslatenboek",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "storefront/public", "-p", "8090", "-c-1"],
      "port": 8090
    },
    {
      "name": "preview-html",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "storefront/public", "-p", "8095", "-c-1"],
      "port": 8095
    },
    {
      "name": "slapp-taget",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "storefront/src/projects/slapp-taget/pages", "-p", "8096", "-c-1"],
      "port": 8096
    }
  ]
}
