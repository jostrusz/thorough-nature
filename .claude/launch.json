{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "/opt/homebrew/bin/pnpm",
      "runtimeArgs": ["dev"],
      "port": 9000,
      "cwd": "backend"
    },
    {
      "name": "storefront",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 8000,
      "cwd": "storefront"
    },
    {
      "name": "storefront-only",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["next", "dev", "-p", "8000"],
      "port": 8000,
      "cwd": "storefront"
    },
    {
      "name": "email-dev",
      "runtimeExecutable": "/opt/homebrew/bin/npx",
      "runtimeArgs": ["email", "dev", "--dir", "src/modules/email-notifications/templates", "--port", "3002"],
      "port": 3002,
      "cwd": "backend",
      "env": {"PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"}
    },
    {
      "name": "dashboard-preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", ".", "-p", "8080", "-c-1"],
      "port": 8080
    },
    {
      "name": "loslatenboek",
      "runtimeExecutable": "/opt/homebrew/bin/npx",
      "runtimeArgs": ["http-server", "storefront/src/projects/loslatenboek/pages", "-p", "8090", "-c-1"],
      "port": 8090,
      "env": {"PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"}
    },
    {
      "name": "preview-html",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "storefront/public", "-p", "8095", "-c-1"],
      "port": 8095
    },
    {
      "name": "slapp-taget",
      "runtimeExecutable": "/opt/homebrew/bin/npx",
      "runtimeArgs": ["http-server", "storefront/src/projects/slapp-taget/pages", "-p", "8096", "-c-1"],
      "port": 8096,
      "env": {"PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"}
    },
    {
      "name": "email-preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "email-previews", "-p", "8097", "-c-1"],
      "port": 8097
    },
    {
      "name": "odpusc-ksiazka",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "storefront/src/projects/odpusc-ksiazka/pages", "-p", "8098", "-c-1"],
      "port": 8098
    },
    {
      "name": "lass-los",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "storefront/src/projects/lass-los/pages", "-p", "8099", "-c-1"],
      "port": 8099
    },
    {
      "name": "psi-superzivot",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "storefront/src/projects/psi-superzivot/pages", "-p", "8100", "-c-1"],
      "port": 8100
    },
    {
      "name": "dehondenbijbel",
      "runtimeExecutable": "/opt/homebrew/bin/npx",
      "runtimeArgs": ["http-server", "storefront/src/projects/dehondenbijbel/pages", "-p", "8101", "-c-1"],
      "port": 8101,
      "env": {"PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"}
    }
  ]
}
